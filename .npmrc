# Supply-chain hardening for pnpm 10+.
# Don't install package versions younger than 7 days — gives the community time
# to detect and report malicious uploads before they reach our lockfile.
minimum-release-age=10080
minimum-release-age-exclude=

# Refuse to install if Node/pnpm versions don't match the project's "engines" /
# "packageManager" fields. Prevents accidental drift across machines and CI.
engine-strict=true

# Lifecycle scripts (preinstall/install/postinstall) are blocked by default in
# pnpm 10+ — packages that genuinely need them must be opted in via
# package.json's `pnpm.onlyBuiltDependencies`. Leave that default alone.
